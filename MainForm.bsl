// Код идёт в том порядке, как расположены элементы в форме 

#Область ПриОткрытииФормы
&НаКлиенте
 Процедура ПриОткрытии(Отказ)
	 Элементы.ТекстОшибки.Видимость = Ложь;
	 РежимРаботы = "ОдинЗакон";
	 РежимАнализа = "НЕПРЕР";
	 УрвЗначи = "0.05";
	 
 КонецПроцедуры

#КонецОбласти

#Область ПроверитьДоступныйРежим
&НаКлиенте
Процедура ПартииПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	 ОбъёмОдин = Истина;
    ПредыдущийОбъём = Неопределено;
    
    // Обращаемся к табличной части через Объект
    Для каждого СтрокаТЧ Из Объект.Партии Цикл
        Если ПредыдущийОбъём <> Неопределено И СтрокаТЧ.ОбъёмПартии <> ПредыдущийОбъём Тогда
            ОбъёмОдин = Ложь;
            Прервать;
        КонецЕсли;
        ПредыдущийОбъём = СтрокаТЧ.ОбъёмПартии;
    КонецЦикла;
    
    Если Не ОбъёмОдин Тогда
        РежимАнализа = "НЕПРЕР";
        Элементы.РежимАнализа.Доступность = Ложь;
		Сообщить("Объёмы партий различаются! Доступен только анализ по непрерывной величине вероятности брака", 
                 СтатусСообщения.Внимание);
	Иначе
		Элементы.РежимАнализа.Доступность = Истина;
		Сообщить("Все объёмы партий одинаковы. Доступны оба режима анализа: ", СтатусСообщения.Информация);    
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьДоступныйРежимКоманда(Команда) 
	ПроверитьДоступныйРежим();
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьДоступныйРежим()
    ОбъёмОдин = Истина;
    ПредыдущийОбъём = Неопределено;
    
    // Обращаемся к табличной части через Объект
    Для каждого СтрокаТЧ Из Объект.Партии Цикл
        Если ПредыдущийОбъём <> Неопределено И СтрокаТЧ.ОбъёмПартии <> ПредыдущийОбъём Тогда
            ОбъёмОдин = Ложь;
            Прервать;
        КонецЕсли;
        ПредыдущийОбъём = СтрокаТЧ.ОбъёмПартии;
    КонецЦикла;
    
    Если Не ОбъёмОдин Тогда
        РежимАнализа = "НЕПРЕР";
        Элементы.РежимАнализа.Доступность = Ложь;
		Сообщить("Объёмы партий различаются! Доступен только анализ по непрерывной величине вероятности брака", 
                 СтатусСообщения.Внимание);
	Иначе
		Элементы.РежимАнализа.Доступность = Истина;
		Сообщить("Все объёмы партий одинаковы. Доступны оба режима анализа. ", СтатусСообщения.Информация);    
	КонецЕсли;
КонецПроцедуры    
#КонецОбласти	

#Область ЗагрузкаФайла
// Выбор файла (универсальный)
&НаКлиенте

Процедура ВыбратьФайл(Команда)
    Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
    Диалог.Заголовок = "Выберите файл с данными";
    Диалог.Фильтр = "Поддерживаемые файлы (*.csv;*.xls;*.xlsx)|*.csv;*.xls;*.xlsx|CSV-файлы (*.csv)|*.csv|Excel-файлы (*.xls;*.xlsx)|*.xls;*.xlsx|Все файлы (*.*)|*.*";
    Диалог.МножественныйВыбор = Ложь;
    
    Оповещение = Новый ОписаниеОповещения("ПослеВыбораФайла", ЭтотОбъект);
    Диалог.Показать(Оповещение);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораФайла(ВыбранныеФайлы, ДопПараметры) Экспорт
    Если ВыбранныеФайлы = Неопределено Или ВыбранныеФайлы.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;
    Объект.ПутьКФайлу = ВыбранныеФайлы[0];
	Сообщить("Выбран файл: " + ВыбранныеФайлы[0]);
КонецПроцедуры

// Загрузка данных (автоматическое определение формата)
&НаКлиенте
Процедура ЗагрузитьДанные(Команда)
    Если ПустаяСтрока(Объект.ПутьКФайлу) Тогда
        Сообщить("Сначала выберите файл!");
        Возврат;
    КонецЕсли;
	
	Объект.Партии.Очистить();
    Объект.СтатусРаботы = "Загрузка данных...";
    
    // Определяем тип файла по расширению
    Расширение = НРег(Прав(Объект.ПутьКФайлу, 4));
    
    Если Расширение = ".xls" ИЛИ Расширение = ".xlsx" Или СтрНайти(Расширение, "xlsx") > 0 Тогда
        // Excel файл
        ЗагрузитьExcelНаСервере(Объект.ПутьКФайлу);
		Элементы.РазделительCSV.Видимость = Ложь;
		Элементы.Партии.Обновить();
    ИначеЕсли Расширение = ".csv" Или СтрНайти(Расширение, "csv") > 0 Тогда
        // CSV файл
        Если ПустаяСтрока(Объект.РазделительCSV) Тогда
            Объект.РазделительCSV = ";";
        КонецЕсли;
        ЗагрузитьCSVНаСервере(Объект.ПутьКФайлу, Объект.РазделительCSV, Объект.КодировкаФайла);
		Элементы.РазделительCSV.Видимость = Истина;
	КонецЕсли;
	ПроверитьДоступныйРежим();
	Объект.РежимАнализа = "НЕПРЕР";
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаИзCSV 

// Загрузка данных
&НаКлиенте
Процедура ЗагрузитьИзCSV(Команда)
    Если ПустаяСтрока(Объект.ПутьКФайлу) Тогда
        Сообщить("Сначала выберите файл!");
        Возврат;
    КонецЕсли;
    
    Если ПустаяСтрока(Объект.РазделительCSV) Тогда
        Объект.РазделительCSV = ";";
    КонецЕсли;
    
    Объект.СтатусРаботы = "Загрузка данных...";
    
    ЗагрузитьCSVНаСервере(Объект.ПутьКФайлу, Объект.РазделительCSV, Объект.КодировкаФайла);
КонецПроцедуры

// Основная логика загрузки на сервере
&НаСервере
Процедура ЗагрузитьCSVНаСервере(ПутьКФайлу, РазделительCSV, КодировкаФайла)
    
    Кодировка = КодировкаТекста.UTF8;
    Если КодировкаФайла = 1 Тогда
        Кодировка = КодировкаТекста.ANSI;
    КонецЕсли;
    
    Попытка
        Чтение = Новый ЧтениеТекста(ПутьКФайлу, Кодировка);
        
        // Читаем заголовок
        СтрокаЗаголовок = Чтение.ПрочитатьСтроку();
        Если СтрокаЗаголовок = Неопределено Тогда
            Чтение.Закрыть();
            Объект.СтатусРаботы = "Ошибка";
			Элементы.ТекстОшибки.Видимость = Истина;
            Объект.ТекстОшибки = "Файл пуст";
            Возврат;
        КонецЕсли;
        
        МассивЗаголовков = СтрРазделить(СтрокаЗаголовок, РазделительCSV, Истина);
        
        ИндексНомерПартии = -1;
        ИндексДата = -1;
        ИндексОбъемПартии = -1;
        ИндексКоличествоБрака = -1;
        
        Для НомерКолонки = 0 По МассивЗаголовков.ВГраница() Цикл
            ИмяКолонки = НРег(СокрЛП(МассивЗаголовков[НомерКолонки]));
            
            Если СтрНайти(ИмяКолонки, "номер") > 0 Или СтрНайти(ИмяКолонки, "парти") > 0 Тогда
                ИндексНомерПартии = НомерКолонки;
            КонецЕсли;
            
            Если СтрНайти(ИмяКолонки, "дат") > 0 Тогда
                ИндексДата = НомерКолонки;
            КонецЕсли;
            
            Если СтрНайти(ИмяКолонки, "объем") > 0 Или СтрНайти(ИмяКолонки, "объём") > 0 Тогда
                ИндексОбъемПартии = НомерКолонки;
            КонецЕсли;
            
            Если СтрНайти(ИмяКолонки, "брак") > 0 Тогда
                ИндексКоличествоБрака = НомерКолонки;
            КонецЕсли;
        КонецЦикла;
        
        // Очищаем табличную часть
        Объект.Партии.Очистить();
        
        // Читаем данные
        СтрокаДанных = Чтение.ПрочитатьСтроку();
        КоличествоЗагруженных = 0;
		КоличествоЗабракованных = 0;
        
        Пока СтрокаДанных <> Неопределено Цикл
            Если Не ПустаяСтрока(СокрЛП(СтрокаДанных)) Тогда
                МассивЗначений = СтрРазделить(СтрокаДанных, РазделительCSV, Истина);
                
                Если МассивЗначений.Количество() >= 4 Тогда
                    НоваяСтрока = Объект.Партии.Добавить();
                    
                    Если ИндексНомерПартии >= 0 Тогда
                        НоваяСтрока.НомерПартии = СокрЛП(МассивЗначений[ИндексНомерПартии]);
                    КонецЕсли;
                    
                    Если ИндексДата >= 0 Тогда
                        НоваяСтрока.Дата = ПреобразоватьВДату(МассивЗначений[ИндексДата]);
                    КонецЕсли;
                    
                    Если ИндексОбъемПартии >= 0 Тогда
                        НоваяСтрока.ОбъёмПартии = ПреобразоватьВЧисло(МассивЗначений[ИндексОбъемПартии]);
                    КонецЕсли;
                    
                    Если ИндексКоличествоБрака >= 0 Тогда
                        НоваяСтрока.КоличествоБрака = ПреобразоватьВЧисло(МассивЗначений[ИндексКоличествоБрака]);
                    КонецЕсли;
                    
                    Если НоваяСтрока.ОбъёмПартии > 0 Тогда
                        НоваяСтрока.ВерФакт = НоваяСтрока.КоличествоБрака / НоваяСтрока.ОбъёмПартии;
                    КонецЕсли;
					
                    КоличествоЗагруженных = КоличествоЗагруженных + 1;
                КонецЕсли;
            КонецЕсли;
            
            СтрокаДанных = Чтение.ПрочитатьСтроку();
        КонецЦикла;
        
        Чтение.Закрыть();
        
        Если КоличествоЗагруженных > 0 Тогда
            Объект.СтатусРаботы = "Готово";
            Сообщить("Загружено строк: " + Строка(КоличествоЗагруженных));
        Иначе
            Объект.СтатусРаботы = "Ошибка";
			Элементы.ТекстОшибки.Видимость = Истина;
            Объект.ТекстОшибки = "Нет данных для загрузки";
        КонецЕсли;
        
    Исключение
        Объект.СтатусРаботы = "Ошибка";
        Объект.ТекстОшибки = ОписаниеОшибки();
		Элементы.ТекстОшибки.Видимость = Истина;
        Сообщить("Ошибка: " + ОписаниеОшибки());
    КонецПопытки;
    
КонецПроцедуры

// Вспомогательные функции
&НаСервере
Функция ПреобразоватьВДату(ЗначениеСтрокой)
    ЗначениеСтрокой = СокрЛП(ЗначениеСтрокой);
    Если ПустаяСтрока(ЗначениеСтрокой) Тогда
        Возврат ТекущаяДата();
    КонецЕсли;
    
    Попытка
        Возврат Дата(ЗначениеСтрокой);
    Исключение
    КонецПопытки;
    
    Если СтрДлина(ЗначениеСтрокой) >= 10 И Сред(ЗначениеСтрокой, 3, 1) = "." Тогда
        Попытка
            День = Число(Сред(ЗначениеСтрокой, 1, 2));
            Месяц = Число(Сред(ЗначениеСтрокой, 4, 2));
            Год = Число(Сред(ЗначениеСтрокой, 7, 4));
            Возврат Дата(Год, Месяц, День);
        Исключение
        КонецПопытки;
    КонецЕсли;
    
    Возврат ТекущаяДата();
КонецФункции

&НаСервере
Функция ПреобразоватьВЧисло(ЗначениеСтрокой)
    ЗначениеСтрокой = СокрЛП(ЗначениеСтрокой);
    Если ПустаяСтрока(ЗначениеСтрокой) Тогда
        Возврат 0;
    КонецЕсли;
    
    ЗначениеСтрокой = СтрЗаменить(ЗначениеСтрокой, ",", ".");
    
    Попытка
        Возврат Число(ЗначениеСтрокой);
    Исключение
        Возврат 0;
    КонецПопытки;
КонецФункции


#КонецОбласти

#Область ЗагрузкаИзExcel
&НаСервере
Процедура ЗагрузитьExcelНаСервере(ПутьКФайлу)
    
    // Создаем табличный документ для чтения файла
    ТабДок = Новый ТабличныйДокумент;
    
    // Пытаемся прочитать файл
    Попытка
        ТабДок.Прочитать(ПутьКФайлу, СпособЧтенияЗначенийТабличногоДокумента.Значение);
    Исключение
        Объект.СтатусРаботы = "Ошибка";
        Объект.ТекстОшибки = "Не удалось прочитать файл: " + ОписаниеОшибки();
        Возврат;
    КонецПопытки;
    
    // Получаем количество строк в таблице
    КоличествоСтрок = ТабДок.ВысотаТаблицы;
    КоличествоКолонок = ТабДок.ШиринаТаблицы;
    
    Если КоличествоСтрок < 2 Тогда
        Объект.СтатусРаботы = "Ошибка";
        Объект.ТекстОшибки = "Файл пуст или содержит только заголовки";
        Возврат;
    КонецЕсли;
    
    // Определяем индексы колонок по заголовкам (первая строка)
    ИндексНомерПартии = 0;
    ИндексДата = 0;
    ИндексОбъемПартии = 0;
    ИндексКоличествоБрака = 0;
    
	Для НомерКолонки = 1 По КоличествоКолонок Цикл
        Заголовок = НРег(СокрЛП(ТабДок.Область(1, НомерКолонки).Текст));
        
        Если СтрНайти(Заголовок, "номер") > 0 Или СтрНайти(Заголовок, "парти") > 0 Тогда
            ИндексНомерПартии = НомерКолонки;
        КонецЕсли;
        
        Если СтрНайти(Заголовок, "дат") > 0 Тогда
            ИндексДата = НомерКолонки;
        КонецЕсли;
        
        Если СтрНайти(Заголовок, "объем") > 0 Или СтрНайти(Заголовок, "объём") > 0 Тогда
            ИндексОбъемПартии = НомерКолонки;
        КонецЕсли;
        
        Если СтрНайти(Заголовок, "брак") > 0 Тогда
            ИндексКоличествоБрака = НомерКолонки;
        КонецЕсли;
	КонецЦикла;
	
	Сообщить("ИндексНомерПартии=" + ИндексНомерПартии + 
         ", ИндексДата=" + ИндексДата + 
         ", ИндексОбъемПартии=" + ИндексОбъемПартии + 
         ", ИндексКоличествоБрака=" + ИндексКоличествоБрака);
    
    // Очищаем табличную часть
    Объект.Партии.Очистить();
    
    // Читаем данные со 2-й строки
    КоличествоЗагруженных = 0;
    КоличествоОшибокВСтроках = 0;
    
    Для НомерСтроки = 2 По КоличествоСтрок Цикл
        
        // Получаем сырые данные из строки
        СыройНомерПартии = ПолучитьЗначениеЯчейки(ТабДок, НомерСтроки, ИндексНомерПартии);
        СыраяДата = ПолучитьЗначениеЯчейки(ТабДок, НомерСтроки, ИндексДата);
        СыройОбъемПартии = ПолучитьЗначениеЯчейки(ТабДок, НомерСтроки, ИндексОбъемПартии);
        СыроеКоличествоБрака = ПолучитьЗначениеЯчейки(ТабДок, НомерСтроки, ИндексКоличествоБрака);
        
        // Валидируем данные
        НомерПартии = ВалидироватьСтроку(СыройНомерПартии, "Строка", 100);
        ДатаПартии = ВалидироватьДату(СыраяДата);
        ОбъемПартии = ВалидироватьЧисло(СыройОбъемПартии, 0, 1000000000, "Объем партии");
        КоличествоБрака = ВалидироватьЧисло(СыроеКоличествоБрака, 0, ОбъемПартии, "Количество брака");
        
        // Если нет номера партии - пропускаем строку
        Если ПустаяСтрока(НомерПартии) Тогда
            Продолжить;
        КонецЕсли;
        
        // Если объем партии = 0, то брак тоже должен быть 0
        Если ОбъемПартии = 0 Тогда
            КоличествоБрака = 0;
        КонецЕсли;
        
        // Добавляем строку
        НоваяСтрока = Объект.Партии.Добавить();
        НоваяСтрока.НомерПартии = НомерПартии;
        НоваяСтрока.Дата = ДатаПартии;
        НоваяСтрока.ОбъёмПартии = ОбъемПартии;
        НоваяСтрока.КоличествоБрака = КоличествоБрака;
        
        // Вычисляем процент брака
        Если ОбъемПартии > 0 Тогда
            НоваяСтрока.ВерФакт = КоличествоБрака / ОбъемПартии;
        Иначе
            НоваяСтрока.ВерФакт = 0;
        КонецЕсли;
        
        КоличествоЗагруженных = КоличествоЗагруженных + 1;
        
        // Логируем предупреждения (если были замены значений)
        Если НомерПартии <> СыройНомерПартии И Не ПустаяСтрока(СыройНомерПартии) Тогда
            КоличествоОшибокВСтроках = КоличествоОшибокВСтроках + 1;
        КонецЕсли;
        
        Если ОбъемПартии <> СыройОбъемПартии И СыройОбъемПартии <> "" Тогда
			КоличествоОшибокВСтроках = КоличествоОшибокВСтроках + 1;
        КонецЕсли;
        
        Если КоличествоБрака <> СыроеКоличествоБрака И СыроеКоличествоБрака <> "" Тогда
            КоличествоОшибокВСтроках = КоличествоОшибокВСтроках + 1;
        КонецЕсли;
        
    КонецЦикла;
    
    Если КоличествоЗагруженных > 0 Тогда
        Объект.СтатусРаботы = "Готово";
        Объект.ТекстОшибки = "";
        Сообщить("Загружено строк из Excel: " + Строка(КоличествоЗагруженных));
        Если КоличествоОшибокВСтроках > 0 Тогда
            Сообщить("Предупреждений по данным: " + Строка(КоличествоОшибокВСтроках));
        КонецЕсли;
    Иначе
        Объект.СтатусРаботы = "Ошибка";
        Объект.ТекстОшибки = "Нет данных для загрузки из Excel";
    КонецЕсли;
    
КонецПроцедуры


Функция ПреобразоватьВДатуExcel(ЗначениеСтрокой)
    ЗначениеСтрокой = СокрЛП(ЗначениеСтрокой);
    Если ПустаяСтрока(ЗначениеСтрокой) Тогда
        Возврат ТекущаяДата();
    КонецЕсли;
    
    Попытка
        Возврат Дата(ЗначениеСтрокой);
    Исключение
    КонецПопытки;
    
    // Пробуем разные форматы дат
    МассивФорматов = Новый Массив;
    МассивФорматов.Добавить("дд.ММ.гггг");
    МассивФорматов.Добавить("дд/ММ/гггг");
    МассивФорматов.Добавить("гггг-ММ-дд");
    МассивФорматов.Добавить("ММ/дд/гггг");
    
    Для Каждого Формат Из МассивФорматов Цикл
        Попытка
            Возврат Дата(ЗначениеСтрокой);
        Исключение
        КонецПопытки;
    КонецЦикла;
    
    Возврат ТекущаяДата();
КонецФункции
#КонецОбласти

#Область ВалидацияДанных

// Получаем значение ячейки
Функция ПолучитьЗначениеЯчейки(ТабДок, НомерСтроки, НомерКолонки)
    Если НомерКолонки <= 0 Тогда
        Возврат "";
    КонецЕсли;
    
    Возврат СокрЛП(ТабДок.Область(НомерСтроки, НомерКолонки).Текст);
КонецФункции

//Оставляем только разрешённые символы (русские и английские) и обрезаем по максимальной длине реквизита
Функция ВалидироватьСтроку(Значение, ТипОжидаемый = "Строка", МаксимальнаяДлина = 0)
    Если ТипОжидаемый = "Строка" Тогда
        Если Значение = Неопределено Или ПустаяСтрока(Значение) Тогда
            Возврат "";
        КонецЕсли;
        
        // Очищаем строку от недопустимых символов (оставляем буквы, цифры, пробелы, дефисы, точки)
        Результат = "";
        Для Индекс = 1 По СтрДлина(Значение) Цикл
            Символ = Сред(Значение, Индекс, 1);
            КодСимвола = КодСимвола(Символ);
            Если (КодСимвола >= 1040 И КодСимвола <= 1103) // Русские буквы
                Или (КодСимвола >= 65 И КодСимвола <= 90)  // Латинские заглавные
                Или (КодСимвола >= 97 И КодСимвола <= 122) // Латинские строчные
                Или (КодСимвола >= 48 И КодСимвола <= 57)  // Цифры
                Или Символ = " " Или Символ = "-" Или Символ = "." Или Символ = "/" Или Символ = "№" Тогда
                Результат = Результат + Символ;
            КонецЕсли;
        КонецЦикла;
        
        // Обрезаем по максимальной длине
        Если МаксимальнаяДлина > 0 И СтрДлина(Результат) > МаксимальнаяДлина Тогда
            Результат = Лев(Результат, МаксимальнаяДлина);
        КонецЕсли;
        
        Возврат СокрЛП(Результат);
    КонецЕсли;
    
    Возврат "";
КонецФункции 

//Проверяем числа: зануляем все текстовые значения; также проверяем, что брака не больше, чем объём партии
Функция ВалидироватьЧисло(Значение, МинЗначение = 0, МаксЗначение = 1000000000, ИмяПоля = "")
    // Обработка различных типов входных данных
    Если Значение = Неопределено Или ПустаяСтрока(Значение) Тогда
        Возврат МинЗначение;
    КонецЕсли;
    
    Попытка
        // Подготавливаем строку для преобразования
        СтрокаЧисло = Строка(Значение);
        
        // Заменяем запятую на точку
        СтрокаЧисло = СтрЗаменить(СтрокаЧисло, ",", ".");
        
        // Удаляем все кроме цифр, точки и минуса
        ОчищеннаяСтрока = "";
        Для Индекс = 1 По СтрДлина(СтрокаЧисло) Цикл
            Символ = Сред(СтрокаЧисло, Индекс, 1);
            Если Символ >= "0" И Символ <= "9" Или Символ = "." Или Символ = "-" Тогда
                ОчищеннаяСтрока = ОчищеннаяСтрока + Символ;
            КонецЕсли;
        КонецЦикла;
        
        // Преобразуем в число
        Если ПустаяСтрока(ОчищеннаяСтрока) Тогда
            Возврат МинЗначение;
        КонецЕсли;
        
        ЧислоЗначение = Число(ОчищеннаяСтрока);
        
        // Проверяем диапазон
        Если ЧислоЗначение < МинЗначение Тогда
            Если ИмяПоля <> "" Тогда
                Сообщить("Внимание: " + ИмяПоля + " (" + Значение + ") меньше минимального значения (" + МинЗначение + "), установлено минимальное");
            КонецЕсли;
            Возврат МинЗначение;
        КонецЕсли;
        
        Если ЧислоЗначение > МаксЗначение Тогда
            Если ИмяПоля <> "" Тогда
                Сообщить("Внимание: " + ИмяПоля + " (" + Значение + ") больше максимального значения (" + МаксЗначение + "), установлено максимальное");
            КонецЕсли;
            Возврат МаксЗначение;
        КонецЕсли;
        
        Возврат ЧислоЗначение;
        
    Исключение
        Если ИмяПоля <> "" Тогда
            Сообщить("Внимание: " + ИмяПоля + " (" + Значение + ") не является числом, установлено значение " + МинЗначение);
        КонецЕсли;
        Возврат МинЗначение;
    КонецПопытки;
КонецФункции 

// И на всякий проверяем дату: дата -> преобразуем в дату 1С -> возврат даты ИЛИ текущей даты
Функция ВалидироватьДату(Значение)
    // Проверка на пустые значения
    Если Значение = Неопределено Или ПустаяСтрока(Строка(Значение)) Тогда
        Возврат '00010101';  // Пустая дата, а не текущая
    КонецЕсли;
    
    // Если уже дата
    Если ТипЗнч(Значение) = Тип("Дата") Тогда
        Возврат Значение;
    КонецЕсли;
    
    // Преобразуем в строку и очищаем
    СтрокаДаты = СокрЛП(Строка(Значение));
    
    // Пробуем преобразовать число Excel в дату (число дней с 1900 года)
    Если ТипЗнч(Значение) = Тип("Число") Или (СтрНайти(СтрокаДаты, ".") = 0 И СтрНайти(СтрокаДаты, "/") = 0 И СтрНайти(СтрокаДаты, "-") = 0) Тогда
        Попытка
            ЧислоДней = Число(СтрокаДаты);
            Если ЧислоДней > 0 И ЧислоДней < 100000 Тогда
                // Excel считает даты с 30.12.1899
                БазоваяДата = Дата(1899, 12, 30);
                Возврат БазоваяДата + ЧислоДней;
            КонецЕсли;
        Исключение
        КонецПопытки;
    КонецЕсли;
    
    // Заменяем разные разделители на точку для унификации
    СтрокаДаты = СтрЗаменить(СтрокаДаты, "/", ".");
    СтрокаДаты = СтрЗаменить(СтрокаДаты, "-", ".");
    
    // Разбираем дату в формате ДД.ММ.ГГГГ или ДД.ММ.ГГ
    Если СтрНайти(СтрокаДаты, ".") > 0 Тогда
        Части = СтрРазделить(СтрокаДаты, ".");
        Если Части.Количество() = 3 Тогда
            День = Число(Части[0]);
            Месяц = Число(Части[1]);
            Год = Число(Части[2]);
            
            // Если год двузначный (ГГ), преобразуем в четырехзначный
            Если Год >= 0 И Год < 30 Тогда
                Год = 2000 + Год;
            ИначеЕсли Год >= 30 И Год < 100 Тогда
                Год = 1900 + Год;
            КонецЕсли;
            
            // Проверяем корректность даты
            Если День >= 1 И День <= 31 И Месяц >= 1 И Месяц <= 12 И Год >= 1900 И Год <= 2100 Тогда
                Попытка
                    Возврат Дата(Год, Месяц, День);
                Исключение
                    // Дата некорректна (например, 31.02.2024)
                    Сообщить("Некорректная дата: " + СтрокаДаты);
                КонецПопытки;
            КонецЕсли;
        КонецЕсли;
    КонецЕсли;
    
    // Пробуем стандартное преобразование (для формата ГГГГ-ММ-ДД)
    Попытка
        Возврат Дата(СтрокаДаты);
    Исключение
    КонецПопытки;
    
    // Если ничего не помогло - возвращаем пустую дату и предупреждение
    Сообщить("Внимание: не удалось преобразовать дату '" + СтрокаДаты + "', установлена пустая дата");
    Возврат '00010101';
КонецФункции
