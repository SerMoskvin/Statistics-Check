  #Область ЭмпирическиеЧастоты

// Для дискретного режима - группировка по значениям
&НаСервере
Функция ПостроитьДискретныеЧастоты(МассивДанных)
    // Находим уникальные значения и считаем их частоту
    ТаблицаЧастот = Новый ТаблицаЗначений;
    ТаблицаЧастот.Колонки.Добавить("Значение", Новый ОписаниеТипов("Число"));
    ТаблицаЧастот.Колонки.Добавить("Частота", Новый ОписаниеТипов("Число"));
    
    Для Каждого Значение Из МассивДанных Цикл
        НайденнаяСтрока = ТаблицаЧастот.Найти(Значение, "Значение");
        Если НайденнаяСтрока = Неопределено Тогда
            НоваяСтрока = ТаблицаЧастот.Добавить();
            НоваяСтрока.Значение = Значение;
            НоваяСтрока.Частота = 1;
        Иначе
            НайденнаяСтрока.Частота = НайденнаяСтрока.Частота + 1;
        КонецЕсли;
    КонецЦикла;
    
    // Сортируем по значению
    ТаблицаЧастот.Сортировать("Значение");
    
    Возврат ТаблицаЧастот;
КонецФункции

// Для непрерывного режима - интервалы по правилу Стёрджеса
&НаСервере
Функция ПостроитьИнтервальныеЧастоты(МассивДанных)
    
    Если МассивДанных.Количество() = 0 Тогда
        Возврат Новый ТаблицаЗначений;
    КонецЕсли;
    
    КоличествоИнтервалов = Цел(1 + 3.322 * Log10(МассивДанных.Количество()));
    
    Если КоличествоИнтервалов < 5 Тогда
        КоличествоИнтервалов = 5;
    КонецЕсли;
    Если КоличествоИнтервалов > 15 Тогда
        КоличествоИнтервалов = 15;
    КонецЕсли;
    
    МинЗнач = МассивДанных[0];
    МаксЗнач = МассивДанных[0];
    Для Каждого Значение Из МассивДанных Цикл
        Если Значение < МинЗнач Тогда МинЗнач = Значение; КонецЕсли;
        Если Значение > МаксЗнач Тогда МаксЗнач = Значение; КонецЕсли;
    КонецЦикла;
    
    Если МаксЗнач = МинЗнач Тогда
        ТаблицаИнтервалов = Новый ТаблицаЗначений;
        ТаблицаИнтервалов.Колонки.Добавить("НижняяГраница", Новый ОписаниеТипов("Число"));
        ТаблицаИнтервалов.Колонки.Добавить("ВерхняяГраница", Новый ОписаниеТипов("Число"));
        ТаблицаИнтервалов.Колонки.Добавить("Частота", Новый ОписаниеТипов("Число"));
        
        НоваяСтрока = ТаблицаИнтервалов.Добавить();
        НоваяСтрока.НижняяГраница = МинЗнач - 0.0001;
        НоваяСтрока.ВерхняяГраница = МаксЗнач + 0.0001;
        НоваяСтрока.Частота = МассивДанных.Количество();
        
        Возврат ТаблицаИнтервалов;
    КонецЕсли;
    
    Размах = МаксЗнач - МинЗнач;
    Шаг = Размах / КоличествоИнтервалов;
    
    ТаблицаИнтервалов = Новый ТаблицаЗначений;
    ТаблицаИнтервалов.Колонки.Добавить("НижняяГраница", Новый ОписаниеТипов("Число"));
    ТаблицаИнтервалов.Колонки.Добавить("ВерхняяГраница", Новый ОписаниеТипов("Число"));
    ТаблицаИнтервалов.Колонки.Добавить("Частота", Новый ОписаниеТипов("Число"));
    
    Для i = 0 По КоличествоИнтервалов - 1 Цикл
        НоваяСтрока = ТаблицаИнтервалов.Добавить();
        НоваяСтрока.НижняяГраница = МинЗнач + i * Шаг;
        
        Если i = КоличествоИнтервалов - 1 Тогда
            НоваяСтрока.ВерхняяГраница = МаксЗнач;
        Иначе
            НоваяСтрока.ВерхняяГраница = МинЗнач + (i + 1) * Шаг;
        КонецЕсли;
        
        НоваяСтрока.Частота = 0;
    КонецЦикла;
    
    //  цикл подсчета частот
    Для Каждого Значение Из МассивДанных Цикл
        НомерИнтервала = 0;
        Для Каждого СтрокаИнтервала Из ТаблицаИнтервалов Цикл
            Если НомерИнтервала = ТаблицаИнтервалов.Количество() - 1 Тогда
                // Последний интервал - включаем правую границу
                Если Значение >= СтрокаИнтервала.НижняяГраница И Значение <= СтрокаИнтервала.ВерхняяГраница Тогда
                    СтрокаИнтервала.Частота = СтрокаИнтервала.Частота + 1;
                    Прервать;
                КонецЕсли;
            Иначе
                // Остальные интервалы
                Если Значение >= СтрокаИнтервала.НижняяГраница И Значение < СтрокаИнтервала.ВерхняяГраница Тогда
                    СтрокаИнтервала.Частота = СтрокаИнтервала.Частота + 1;
                    Прервать;
                КонецЕсли;
            КонецЕсли;
            НомерИнтервала = НомерИнтервала + 1;
        КонецЦикла;
    КонецЦикла;
    
    Возврат ТаблицаИнтервалов;
КонецФункции

#КонецОбласти

#Область ТеоретическиеЧастоты

// Функция Лапласа Ф(x) - интеграл от 0 до x стандартного нормального распределения
Функция ФункцияЛапласа(x)
    Если x >= 0 Тогда
        t = 1 / (1 + 0.2316419 * x);
        Полином = 0.31938153 * t - 0.356563782 * Pow(t, 2) + 1.781477937 * Pow(t, 3) 
                - 1.821255978 * Pow(t, 4) + 1.330274429 * Pow(t, 5);
        Плотность = Exp(-Pow(x, 2) / 2) / Sqrt(2 * 3.14159265359);
        Возврат 0.5 - Плотность * Полином;
    Иначе
        Возврат -ФункцияЛапласа(-x);
    КонецЕсли;
КонецФункции

// Теоретические частоты для нормального распределения 
&НаСервере
Функция ТеорЧастотыНормальное(ТаблицаИнтервалов, Среднее, СКО, ОбщееКоличество)
    ТеорЧастоты = Новый Массив;
    
    Для Каждого Строка Из ТаблицаИнтервалов Цикл
        a = Строка.НижняяГраница;
        b = Строка.ВерхняяГраница;
        
        // Стандартизация границ
        z_a = (a - Среднее) / СКО;
        z_b = (b - Среднее) / СКО;
        
        // Вероятность попадания в интервал
        Вероятность = ФункцияЛапласа(z_b) - ФункцияЛапласа(z_a);
        
        ТеорЧастота = Вероятность * ОбщееКоличество;
        Если ТеорЧастота < 0 Тогда
            ТеорЧастота = 0;
        КонецЕсли;
        
        ТеорЧастоты.Добавить(ТеорЧастота);
    КонецЦикла;
    
    Возврат ТеорЧастоты;
КонецФункции

// Гамма-функция через аппроксимацию Стирлинга
&НаСервере
Функция ГаммаФункция(x)
    Если x <= 0 Тогда
        Возврат 0;
    КонецЕсли;
    
    // Для целых и полуцелых - точные значения
    Если x = 1 Тогда
        Возврат 1;
    КонецЕсли;
    
    Если x = 0.5 Тогда
        Возврат Sqrt(3.14159265359);
    КонецЕсли;
    
    // Аппроксимация Стирлинга
    Если x > 0 Тогда
        Возврат Sqrt(2 * 3.14159265359 / x) * Pow(x / 2.718281828, x) * 
               (1 + 1/(12*x) + 1/(288*Pow(x,2)));
    КонецЕсли; 
    
    Возврат 0;
КонецФункции

// Бета-функция 
&НаСервере
Функция БетаФункция(alpha, beta)
    Возврат ГаммаФункция(alpha) * ГаммаФункция(beta) / ГаммаФункция(alpha + beta);
КонецФункции

// Оценка параметров бета-распределения 
&НаСервере
Функция ОценитьПараметрыБета(Среднее, Дисперсия)
    Если Среднее <= 0 Или Среднее >= 1 Или Дисперсия <= 0 Тогда
        alpha = 1;
        beta = 1;
    Иначе
        Вспомогательная = Среднее * (1 - Среднее) / Дисперсия - 1;
        Если Вспомогательная <= 0 Тогда
            Вспомогательная = 0.1;
        КонецЕсли;
        alpha = Среднее * Вспомогательная;
        beta = (1 - Среднее) * Вспомогательная;
    КонецЕсли;
    
    Результат = Новый Структура;
    Результат.Вставить("alpha", alpha);
    Результат.Вставить("beta", beta);
    
    Возврат Результат;
КонецФункции

// Плотность бета-распределения
&НаСервере
Функция ПлотностьБета(x, alpha, beta)
    Если x <= 0 Или x >= 1 Тогда
        Возврат 0;
    КонецЕсли;
    
    Нормировка = 1 / БетаФункция(alpha, beta);
    Возврат Нормировка * Pow(x, alpha - 1) * Pow(1 - x, beta - 1);
КонецФункции

// Теоретические частоты для бета-распределения 
&НаСервере
Функция ТеорЧастотыБета(ТаблицаИнтервалов, alpha, beta, ОбщееКоличество)
    ТеорЧастоты = Новый Массив;
    
    Для Каждого Строка Из ТаблицаИнтервалов Цикл
        // Численное интегрирование методом прямоугольников
        a = Строка.НижняяГраница;
        b = Строка.ВерхняяГраница;
        
        Если a < 0 Тогда a = 0; КонецЕсли;
        Если b > 1 Тогда b = 1; КонецЕсли;
        
        Шагов = 50;
        Шаг = (b - a) / Шагов;
        Интеграл = 0;
        
        Для i = 0 По Шагов - 1 Цикл
            x = a + (i + 0.5) * Шаг;
            Интеграл = Интеграл + ПлотностьБета(x, alpha, beta) * Шаг;
        КонецЦикла;
        
        ТеорЧастоты.Добавить(Интеграл * ОбщееКоличество);
    КонецЦикла;
    
    Возврат ТеорЧастоты;
КонецФункции

// Оценка параметров равномерного распределения )
&НаСервере
Функция ОценитьПараметрыРавномерное(Среднее, СКО)
    a_оценка = Среднее - Sqrt(3) * СКО;
    b_оценка = Среднее + Sqrt(3) * СКО;
    
    Результат = Новый Структура;
    Результат.Вставить("a", a_оценка);
    Результат.Вставить("b", b_оценка);
    
    Возврат Результат;
КонецФункции

// Теоретические частоты для равномерного распределения 
&НаСервере
Функция ТеорЧастотыРавномерное(ТаблицаИнтервалов, a, b, ОбщееКоличество)
    ТеорЧастоты = Новый Массив;
    ДлинаВсего = b - a;
    
    Если ДлинаВсего <= 0 Тогда
        ДлинаВсего = 1;
    КонецЕсли;
    
    Для Каждого Строка Из ТаблицаИнтервалов Цикл
        ДлинаИнтервала = Строка.ВерхняяГраница - Строка.НижняяГраница;
        Вероятность = ДлинаИнтервала / ДлинаВсего;
        ТеорЧастоты.Добавить(Вероятность * ОбщееКоличество);
    КонецЦикла;
    
    Возврат ТеорЧастоты;
КонецФункции

// Теоретические частоты для Пуассона
&НаСервере
Функция ТеорЧастотыПуассона(ТаблицаДискретныхЧастот, Лямбда, ОбщееКоличество)
    ТеорЧастоты = Новый Массив;
    
    Для Каждого Строка Из ТаблицаДискретныхЧастот Цикл
        k = Строка.Значение;
        
        Вероятность = Pow(Лямбда, k) * Exp(-Лямбда) / Факториал(k);
        
        ТеорЧастоты.Добавить(Вероятность * ОбщееКоличество);
    КонецЦикла;
    
    Возврат ТеорЧастоты;
КонецФункции

// Теоретические частоты для биномиального распределения
&НаСервере
Функция ТеорЧастотыБиномиальное(ТаблицаДискретныхЧастот, n, p, ОбщееКоличество)
    ТеорЧастоты = Новый Массив;
    
    Для Каждого Строка Из ТаблицаДискретныхЧастот Цикл
        k = Строка.Значение;
        
        Вероятность = ЧислоСочетаний(n, k) * Pow(p, k) * Pow(1 - p, n - k);
        
        ТеорЧастоты.Добавить(Вероятность * ОбщееКоличество);
    КонецЦикла;
    
    Возврат ТеорЧастоты;
КонецФункции

#КонецОбласти

#Область КритерийХиКвадрат

// Статистика Хи-квадрат 
&НаСервере
Функция ВычислитьХиКвадрат(ЭмпирическиеЧастоты, ТеоретическиеЧастоты)
    ХиКвадрат = 0;
    
    Для i = 0 По ЭмпирическиеЧастоты.Количество() - 1 Цикл
        Если ТеоретическиеЧастоты[i] > 0 Тогда
            Разность = ЭмпирическиеЧастоты[i] - ТеоретическиеЧастоты[i];
            ХиКвадрат = ХиКвадрат + Pow(Разность, 2) / ТеоретическиеЧастоты[i];
        КонецЕсли;
    КонецЦикла;
    
    Возврат ХиКвадрат;
КонецФункции

// Число степеней свободы 
&НаСервере
Функция ВычислитьСтепениСвободы(КоличествоГрупп, ЧислоПараметров)
    Возврат КоличествоГрупп - 1 - ЧислоПараметров;
КонецФункции

// Критическое значение Хи-квадрат (приближённое)
&НаСервере
Функция ВычислитьКритическоеЗначение(СтепениСвободы, УровеньЗначимости)
    Если СтепениСвободы <= 0 Тогда
        Возврат 0;
    КонецЕсли;
    
    // Аппроксимация через нормальное распределение
    // Находим квантиль нормального распределения
    z = КвантильНормальногоРаспределения(1 - УровеньЗначимости);
    
    // Формула Вилсона-Хилферти
    ХиКрит = СтепениСвободы * Pow(1 - 2/(9*СтепениСвободы) + z * Sqrt(2/(9*СтепениСвободы)), 3);
    
    Возврат ХиКрит;
КонецФункции

// Квантиль нормального распределения
&НаСервере
Функция КвантильНормальногоРаспределения(Вероятность)
    Если Вероятность <= 0 Тогда
        Возврат -10;
    КонецЕсли;
    Если Вероятность >= 1 Тогда
        Возврат 10;
    КонецЕсли;
    
    p = Вероятность;
    Если p > 0.5 Тогда
        p = 1 - p;
    КонецЕсли;
    
    t = Sqrt(-2 * Log(p));
    
    c0 = 2.515517;
    c1 = 0.802853;
    c2 = 0.010328;
    d1 = 1.432788;
    d2 = 0.189269;
    d3 = 0.001308;
    
    z = t - (c0 + c1 * t + c2 * Pow(t, 2)) / (1 + d1 * t + d2 * Pow(t, 2) + d3 * Pow(t, 3));
    
    Если Вероятность > 0.5 Тогда
        Возврат -z;
    Иначе
        Возврат z;
    КонецЕсли;
КонецФункции

// P-value для Хи-квадрат (приближённое)
&НаСервере
Функция ВычислитьPValue(ХиКвадрат, СтепениСвободы)
    Если СтепениСвободы <= 0 Тогда
        Возврат 1;
    КонецЕсли;
    
    // Аппроксимация через нормальное распределение
    z = (Pow(ХиКвадрат / СтепениСвободы, 1/3) - (1 - 2/(9*СтепениСвободы))) / Sqrt(2/(9*СтепениСвободы));
    
    pValue = 1 - ФункцияЛапласа(z);
    
    Если pValue < 0 Тогда
        pValue = 0;
    КонецЕсли;
    Если pValue > 1 Тогда
        pValue = 1;
    КонецЕсли;
    
    Возврат pValue;
КонецФункции

#КонецОбласти

  #Область ОбъединениеГрупп

// Объединение групп, где теоретическая частота < 5
&НаСервере
Функция ОбъединитьМалыеГруппы(ЭмпирическиеЧастоты, ТеоретическиеЧастоты, ОбъемВыборки)
    
    НовыеЭмпирические = Новый Массив;
    НовыеТеоретические = Новый Массив;
    
    // Определяем порог объединения в зависимости от объема выборки
    ПорогОбъединения = 5;
    Если ОбъемВыборки >= 1000 Тогда
        ПорогОбъединения = 10;
    КонецЕсли;
    Если ОбъемВыборки >= 5000 Тогда
        ПорогОбъединения = 15;
    КонецЕсли;
    Если ОбъемВыборки >= 10000 Тогда
        ПорогОбъединения = 20;
    КонецЕсли;
    
    // Для очень маленьких выборок используем более гибкий подход
    Если ОбъемВыборки < 50 Тогда
        ПорогОбъединения = 2;
    КонецЕсли;
    
    НакопленнаяЭмпирическая = 0;
    НакопленнаяТеоретическая = 0;
    
    Количество = ЭмпирическиеЧастоты.Количество();
    
    Для i = 0 По Количество - 1 Цикл
        НакопленнаяЭмпирическая = НакопленнаяЭмпирическая + ЭмпирическиеЧастоты[i];
        
        Если i < ТеоретическиеЧастоты.Количество() Тогда
            НакопленнаяТеоретическая = НакопленнаяТеоретическая + ТеоретическиеЧастоты[i];
        КонецЕсли;
        
        // Проверяем условие объединения
        Объединять = Ложь;
        
        Если НакопленнаяТеоретическая >= ПорогОбъединения Тогда
            Объединять = Истина;
        ИначеЕсли i = Количество - 1 Тогда
            // Последняя группа - объединяем в любом случае
            Объединять = Истина;
        ИначеЕсли ОбъемВыборки < 100 И НакопленнаяТеоретическая >= 2 Тогда
            // Для малых выборок используем более низкий порог
            Объединять = Истина;
        КонецЕсли;
        
        Если Объединять Тогда
            НовыеЭмпирические.Добавить(НакопленнаяЭмпирическая);
            НовыеТеоретические.Добавить(НакопленнаяТеоретическая);
            
            НакопленнаяЭмпирическая = 0;
            НакопленнаяТеоретическая = 0;
        КонецЕсли;
    КонецЦикла;
    
    // Проверка на слишком малое количество групп после объединения
    Если НовыеЭмпирические.Количество() < 2 И ОбъемВыборки >= 50 Тогда
        // Если осталась только одна группа, пытаемся разбить на две
        НовыеЭмпирические = Новый Массив;
        НовыеТеоретические = Новый Массив;
        
        Середина = Цел(ЭмпирическиеЧастоты.Количество() / 2);
        
        СуммаЭмпПервая = 0;
        СуммаТеорПервая = 0;
        Для i = 0 По Середина - 1 Цикл
            СуммаЭмпПервая = СуммаЭмпПервая + ЭмпирическиеЧастоты[i];
            Если i < ТеоретическиеЧастоты.Количество() Тогда
                СуммаТеорПервая = СуммаТеорПервая + ТеоретическиеЧастоты[i];
            КонецЕсли;
        КонецЦикла;
        
        СуммаЭмпВторая = 0;
        СуммаТеорВторая = 0;
        Для i = Середина По ЭмпирическиеЧастоты.Количество() - 1 Цикл
            СуммаЭмпВторая = СуммаЭмпВторая + ЭмпирическиеЧастоты[i];
            Если i < ТеоретическиеЧастоты.Количество() Тогда
                СуммаТеорВторая = СуммаТеорВторая + ТеоретическиеЧастоты[i];
            КонецЕсли;
        КонецЦикла;
        
        НовыеЭмпирические.Добавить(СуммаЭмпПервая);
        НовыеЭмпирические.Добавить(СуммаЭмпВторая);
        НовыеТеоретические.Добавить(СуммаТеорПервая);
        НовыеТеоретические.Добавить(СуммаТеорВторая);
    КонецЕсли;
    
    Результат = Новый Структура;
    Результат.Вставить("Эмпирические", НовыеЭмпирические);
    Результат.Вставить("Теоретические", НовыеТеоретические);
    
    Возврат Результат;
КонецФункции

#КонецОбласти

#Область ПроверкаГипотез

&НаКлиенте
Процедура ПроверитьГипотезу(Команда)
    Если Объект.Партии.Количество() = 0 Тогда
        Сообщить("Нет данных для анализа. Загрузите или впишите данные");
        Возврат;
    КонецЕсли;
        
    Объект.СтатусРаботы = "Проверка гипотез...";
    
    ПроверитьГипотезуНаСервере(Объект.РежимАнализа, Объект.РежимРаботы, 
        Объект.ВыбранныйЗакон, Объект.УрвЗначи);
КонецПроцедуры

&НаСервере
Процедура ПроверитьГипотезуНаСервере(РежимАнализа, РежимРаботы, ВыбранныйЗакон, УровеньЗначимости)
     Сообщить("=== НАЧАЛО ПРОВЕРКИ ===");
    Сообщить("РежимАнализа=" + РежимАнализа);
    Сообщить("РежимРаботы=" + РежимРаботы);
    Сообщить("ВыбранныйЗакон=" + ВыбранныйЗакон);
    Сообщить("УровеньЗначимости=" + УровеньЗначимости);
    // Собираем данные
    МассивДанных = СобратьДанныеДляАнализа(РежимАнализа);
    
    Если РежимРаботы = "ОдинЗакон" Тогда
        // Проверяем один выбранный закон
        Результат = ПроверитьОдинЗакон(МассивДанных, ВыбранныйЗакон, УровеньЗначимости, РежимАнализа);
        ЗаполнитьРезультатыНаФорме(Результат, ВыбранныйЗакон);
        
    Иначе // "ВсеЗаконы"
        // Определяем список законов для данного режима
        Если РежимАнализа = "ДИСКР" Тогда
            СписокЗаконов = Новый Массив;
            СписокЗаконов.Добавить("Пуассона");
            СписокЗаконов.Добавить("Биномиальное");
        Иначе // "Непрерывный"
            СписокЗаконов = Новый Массив;
            СписокЗаконов.Добавить("Нормальное");
            СписокЗаконов.Добавить("Бета");
            СписокЗаконов.Добавить("Равномерное");
        КонецЕсли;
        
        // Проверяем все законы и выбираем лучший
        ЛучшийРезультат = Неопределено;
        ЛучшийЗакон = "";
        МинХиКвадрат = 999999999;
        
        Для Каждого Закон Из СписокЗаконов Цикл
            Результат = ПроверитьОдинЗакон(МассивДанных, Закон, УровеньЗначимости, РежимАнализа);
            
            Если Результат.ХиКвадрат < МинХиКвадрат Тогда
                МинХиКвадрат = Результат.ХиКвадрат;
                ЛучшийРезультат = Результат;
                ЛучшийЗакон = Закон;
            КонецЕсли;
        КонецЦикла;
        
        // Заполняем форму результатами лучшего закона
        ЗаполнитьРезультатыНаФорме(ЛучшийРезультат, ЛучшийЗакон);
    КонецЕсли;
    
    Объект.СтатусРаботы = "Готово";
	Сообщить("=== ПЕРВЫЕ 10 ЗНАЧЕНИЙ ===");
Для i = 0 По МассивДанных.Количество() - 1 И i < 10 Цикл
    Сообщить("Значение[" + i + "] = " + МассивДанных[i]);
КонецЦикла;
КонецПроцедуры

// Проверка одного конкретного закона
&НаСервере
Функция ПроверитьОдинЗакон(МассивДанных, ИмяЗакона, УровеньЗначимости, РежимАнализа)
    
    Результат = Новый Структура;
    Результат.Вставить("Среднее", 0);
    Результат.Вставить("Дисперсия", 0);
    Результат.Вставить("СКО", 0);
    Результат.Вставить("ХиКвадрат", 0);
    Результат.Вставить("СтепениСвободы", 0);
    Результат.Вставить("КритическоеЗначение", 0);
    Результат.Вставить("PValue", 0);
    Результат.Вставить("ГипотезаПринимается", Ложь);
    Результат.Вставить("ЭмпирическиеЧастоты", Новый Массив);
    Результат.Вставить("ТеоретическиеЧастоты", Новый Массив);
    
    // 1. Вычисляем базовые статистики
    Среднее = ВычислитьСреднее(МассивДанных);
    Дисперсия = ВычислитьДисперсию(МассивДанных, Среднее);
    СКО = ВычислитьСКО(Дисперсия);
    
    Результат.Среднее = Среднее;
    Результат.Дисперсия = Дисперсия;
    Результат.СКО = СКО;  
	
	Если Объект.РежимРаботы = Неопределено  Тогда  
		Сообщить("Сначала выберите режим работы!", СтатусСообщения.Внимание);
	КонецЕсли;
    // 2. Строим эмпирические частоты
    Если РежимАнализа = "ДИСКР" Тогда
        ТаблицаЧастот = ПостроитьДискретныеЧастоты(МассивДанных);
        КоличествоГрупп = ТаблицаЧастот.Количество();
        
        // Собираем эмпирические частоты в массив
        ЭмпирическиеЧастоты = Новый Массив;
        Для Каждого Строка Из ТаблицаЧастот Цикл
            ЭмпирическиеЧастоты.Добавить(Строка.Частота);
        КонецЦикла;
        
    Иначе // "Непрерывный"
        ТаблицаИнтервалов = ПостроитьИнтервальныеЧастоты(МассивДанных);
        КоличествоГрупп = ТаблицаИнтервалов.Количество();
        
        ЭмпирическиеЧастоты = Новый Массив;
        Для Каждого Строка Из ТаблицаИнтервалов Цикл
            ЭмпирическиеЧастоты.Добавить(Строка.Частота);
        КонецЦикла;
    КонецЕсли;
    
    // 3. Вычисляем теоретические частоты в зависимости от закона
    ТеоретическиеЧастоты = Новый Массив;
    ЧислоПараметров = 0;
    
    Если ИмяЗакона = "НОРМ" Тогда
        ТеоретическиеЧастоты = ТеорЧастотыНормальное(ТаблицаИнтервалов, Среднее, СКО, МассивДанных.Количество());
        ЧислоПараметров = 2; // μ и σ
        
    ИначеЕсли ИмяЗакона = "БЕТА" Тогда
        ПараметрыБета = ОценитьПараметрыБета(Среднее, Дисперсия);
        ТеоретическиеЧастоты = ТеорЧастотыБета(ТаблицаИнтервалов, ПараметрыБета.alpha, ПараметрыБета.beta, МассивДанных.Количество());
        ЧислоПараметров = 2; // α и β
        
    ИначеЕсли ИмяЗакона = "РАВН" Тогда
        ПараметрыРавн = ОценитьПараметрыРавномерное(Среднее, СКО);
        ТеоретическиеЧастоты = ТеорЧастотыРавномерное(ТаблицаИнтервалов, ПараметрыРавн.a, ПараметрыРавн.b, МассивДанных.Количество());
        ЧислоПараметров = 2; // a и b
        
    ИначеЕсли ИмяЗакона = "ПУАСС" Тогда
        Лямбда = Среднее;
        ТеоретическиеЧастоты = ТеорЧастотыПуассона(ТаблицаЧастот, Лямбда, МассивДанных.Количество());
        ЧислоПараметров = 1; // λ
        
    ИначеЕсли ИмяЗакона = "БИНОМ" Тогда
        // n - размер партии (берём из первой строки или из реквизита)
        Если Объект.Партии.Количество() > 0 Тогда
            n = Объект.Партии[0].ОбъёмПартии;
        Иначе
            n = 100;
        КонецЕсли;
        p = Среднее / n;
        ТеоретическиеЧастоты = ТеорЧастотыБиномиальное(ТаблицаЧастот, n, p, МассивДанных.Количество());
        ЧислоПараметров = 1; // p (n известно)
    КонецЕсли;
    
    // 4. Объединяем группы с малыми частотами
    Объединенные = ОбъединитьМалыеГруппы(ЭмпирическиеЧастоты, ТеоретическиеЧастоты, МассивДанных.Количество());
ЭмпирическиеЧастоты = Объединенные.Эмпирические;
ТеоретическиеЧастоты = Объединенные.Теоретические;
    
    // 5. Вычисляем Хи-квадрат
    ХиКвадрат = ВычислитьХиКвадрат(ЭмпирическиеЧастоты, ТеоретическиеЧастоты);
    
    // 6. Степени свободы
    СтепениСвободы = ВычислитьСтепениСвободы(ЭмпирическиеЧастоты.Количество(), ЧислоПараметров);
    Если СтепениСвободы < 1 Тогда
        СтепениСвободы = 1;
    КонецЕсли;
    
    // 7. Критическое значение
    КритическоеЗначение = ВычислитьКритическоеЗначение(СтепениСвободы, УровеньЗначимости);
    
    // 8. P-value
    PValue = ВычислитьPValue(ХиКвадрат, СтепениСвободы);
    
    // 9. Проверка гипотезы     ГипотезаПринимается = ХиКвадрат < КритическоеЗначение;
    
    Результат.ХиКвадрат = ХиКвадрат;
    Результат.СтепениСвободы = СтепениСвободы;
    Результат.КритическоеЗначение = КритическоеЗначение;
    Результат.PValue = PValue;
    Результат.ГипотезаПринимается =  ХиКвадрат < КритическоеЗначение;
    Результат.ЭмпирическиеЧастоты = ЭмпирическиеЧастоты;
    Результат.ТеоретическиеЧастоты = ТеоретическиеЧастоты;
    
    Возврат Результат;
КонецФункции

#КонецОбласти

#Область ВыводРезультатов

&НаСервере
Процедура ЗаполнитьРезультатыНаФорме(Результат, ИмяЗакона)
    
    // Основные показатели
    Объект.Среднее = Окр(Результат.Среднее, 6);
    Объект.Дисперсия = Окр(Результат.Дисперсия, 6);
    Объект.СКО = Окр(Результат.СКО, 6);
    
    Объект.ХиКвадрат = Окр(Результат.ХиКвадрат, 4);
    Объект.СтепеньСвободы = Результат.СтепениСвободы;
    Объект.КритЗначение = Окр(Результат.КритическоеЗначение, 4);
    Объект.PValue = Окр(Результат.PValue, 6);
    
    // Результат проверки
    Если Результат.ГипотезаПринимается Тогда
        Объект.РезультатПроверки = "Гипотеза принимается: данные соответствуют закону " + ИмяЗакона;
    Иначе
        Объект.РезультатПроверки = "Гипотеза отвергается: данные НЕ соответствуют закону " + ИмяЗакона;
    КонецЕсли;
    
    // Табличная часть Частоты
    Объект.Частоты.Очистить();
    
    Для i = 0 По Результат.ЭмпирическиеЧастоты.Количество() - 1 Цикл
        НоваяСтрока = Объект.Частоты.Добавить();
        НоваяСтрока.НомерИнтервала = i + 1;
        НоваяСтрока.ЭмпирическаяЧастота = Результат.ЭмпирическиеЧастоты[i];
        НоваяСтрока.ТеоретическаяЧастота = Окр(Результат.ТеоретическиеЧастоты[i], 2);
        
        Если Результат.ТеоретическиеЧастоты[i] > 0 Тогда
            НоваяСтрока.ВкладВХиКвадрат = Окр(
                Pow(Результат.ЭмпирическиеЧастоты[i] - Результат.ТеоретическиеЧастоты[i], 2) / 
                Результат.ТеоретическиеЧастоты[i], 4);
        Иначе
            НоваяСтрока.ВкладВХиКвадрат = 0;
		КонецЕсли;
    КонецЦикла;
    Сообщить("Количество эмпирических частот: " + Результат.ЭмпирическиеЧастоты.Количество());
Сообщить("Количество теоретических частот: " + Результат.ТеоретическиеЧастоты.Количество());
КонецПроцедуры

