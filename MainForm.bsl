    ПостроитьГистограммуНаСервере();
КонецПроцедуры

&НаСервере
&НаСервере
Процедура ПостроитьГистограммуНаСервере()
    
    // Проверяем, что диаграмма существует
    Если Объект.Диаграмма = Неопределено Тогда
        СоздатьДиаграммуНаСервере();
    КонецЕсли;
    
    // Очищаем данные диаграммы
    Объект.Диаграмма.Очистить();
    Объект.Диаграмма.Обновление = Ложь;
    Объект.Диаграмма.АвтоТранспонирование = Ложь;
    
    // Определяем количество интервалов
    КоличествоДанных = Объект.Партии.Количество();
    Если КоличествоДанных = 0 Тогда
        Сообщить("Нет данных для построения диаграммы");
        Возврат;
    КонецЕсли;
    
    КоличествоИнтервалов = Цел(1 + 3.322 * Log10(КоличествоДанных));
    Если КоличествоИнтервалов < 5 Тогда
        КоличествоИнтервалов = 5;
    КонецЕсли;
    Если КоличествоИнтервалов > 15 Тогда
        КоличествоИнтервалов = 15;
    КонецЕсли;
    
    // Находим минимум и максимум
    МинБрак = Объект.Партии[0].КоличествоБрака;
    МаксБрак = Объект.Партии[0].КоличествоБрака;
    
    Для Каждого Строка Из Объект.Партии Цикл
        Если Строка.КоличествоБрака < МинБрак Тогда
            МинБрак = Строка.КоличествоБрака;
        КонецЕсли;
        Если Строка.КоличествоБрака > МаксБрак Тогда
            МаксБрак = Строка.КоличествоБрака;
        КонецЕсли;
    КонецЦикла;
    
    // Добавляем зазор
    Дельта = (МаксБрак - МинБрак) * 0.01;
    Если Дельта = 0 Тогда
        Дельта = 1;
    КонецЕсли;
    МинБрак = МинБрак - Дельта;
    МаксБрак = МаксБрак + Дельта;
    
    // Ширина интервала
    Шаг = (МаксБрак - МинБрак) / КоличествоИнтервалов;
    
    // Создаем серию
    СерияЧастота = Объект.Диаграмма.Серии.Добавить("Частота");
    
    // Массив для хранения подписей и значений
    МассивПодписей = Новый Массив;
    МассивЗначений = Новый Массив;
    
    // Подсчитываем частоты
    Для i = 0 По КоличествоИнтервалов - 1 Цикл
        НижняяГраница = МинБрак + i * Шаг;
        ВерхняяГраница = МинБрак + (i + 1) * Шаг;
        
        // Подсчитываем частоту
        Частота = 0;
        Для Каждого Строка Из Объект.Партии Цикл
            Если Строка.КоличествоБрака >= НижняяГраница И Строка.КоличествоБрака < ВерхняяГраница Тогда
                Частота = Частота + 1;
            КонецЕсли;
        КонецЦикла;
        
        // Создаем подпись в формате "нижняя - верхняя"
        Подпись = Окр(НижняяГраница, 2) + " - " + Окр(ВерхняяГраница, 2);
        МассивПодписей.Добавить(Подпись);
        МассивЗначений.Добавить(Частота);
        
        // Устанавливаем точку с текстовой подписью
        ТочкаДиаграммы = Объект.Диаграмма.УстановитьТочку(Подпись);
        Объект.Диаграмма.УстановитьЗначение(ТочкаДиаграммы, СерияЧастота, Частота);
    КонецЦикла;
        
    // Настройка внешнего вида
    Объект.Диаграмма.ТипДиаграммы = ТипДиаграммы.Гистограмма;
    Объект.Диаграмма.ОтображатьЛегенду = Истина;
    Объект.Диаграмма.Обновление = Истина;
    Объект.Диаграмма.АвтоТранспонирование = Истина;
    
    Сообщить("Построено интервалов: " + КоличествоИнтервалов);
КонецПроцедуры

&НаСервере
Процедура СоздатьДиаграммуНаСервере()
    // Если нужно программно создать реквизит диаграммы
    нРекв = Новый Массив;
    РеквГраф = Новый РеквизитФормы("Диаграмма", Новый ОписаниеТипов("Диаграмма"));
    нРекв.Добавить(РеквГраф);
    ИзменитьРеквизиты(нРекв);
    
    // Создаем элемент формы для отображения диаграммы
    ЭлементДиаграмма = ЭтаФорма.Элементы.Добавить("Диаграмма", Тип("ПолеФормы"), ЭтаФорма);
    ЭлементДиаграмма.Вид = ВидПоляФормы.ПолеДиаграммы;
    ЭлементДиаграмма.ПутьКДанным = "Диаграмма";
КонецПроцедуры

