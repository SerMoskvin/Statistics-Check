// Выборочное среднее 
&НаСервере
Функция ВычислитьСреднее(МассивЗначений)
    Если МассивЗначений.Количество() = 0 Тогда
        Возврат 0;
    КонецЕсли;
    
    Сумма = 0;
    Для Каждого Значение Из МассивЗначений Цикл
        Сумма = Сумма + Значение;
    КонецЦикла;
    
    Возврат Сумма / МассивЗначений.Количество();
КонецФункции

// Выборочная дисперсия  - несмещённая оценка
&НаСервере
Функция ВычислитьДисперсию(МассивЗначений, Среднее)
    Если МассивЗначений.Количество() <= 1 Тогда
        Возврат 0;
    КонецЕсли;
    
    СуммаКвадратов = 0;
    Для Каждого Значение Из МассивЗначений Цикл
        СуммаКвадратов = СуммаКвадратов + (Значение - Среднее) * (Значение - Среднее);
    КонецЦикла;
    
    // N-1 для несмещённой оценки
    Возврат СуммаКвадратов / (МассивЗначений.Количество() - 1);
КонецФункции

// СКО 
&НаСервере
Функция ВычислитьСКО(Дисперсия)
    Возврат Sqrt(Дисперсия);
КонецФункции

