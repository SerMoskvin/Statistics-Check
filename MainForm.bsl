// Факториал
&НаСервере
Функция Факториал(n)
    Если n <= 1 Тогда
        Возврат 1;
    КонецЕсли;
    
    Результат = 1;
    Для i = 2 По n Цикл
        Результат = Результат * i;
    КонецЦикла;
    
    Возврат Результат;
КонецФункции

// Число сочетаний C(n,k) 
&НаСервере
Функция ЧислоСочетаний(n, k)
    Если k < 0 Или k > n Тогда
        Возврат 0;
    КонецЕсли;
    Если k = 0 Или k = n Тогда
        Возврат 1;
    КонецЕсли;
    
    // Оптимизация: используем свойство симметрии
    Если k > n - k Тогда
        k = n - k;
    КонецЕсли;
    
    Результат = 1;
    Для i = 1 По k Цикл
        Результат = Результат * (n - k + i) / i;
    КонецЦикла;
    
    Возврат Результат;
КонецФункции

#КонецОбласти

 #Область СборДанных

&НаСервере
Функция СобратьДанныеДляАнализа(РежимАнализа)
    МассивДанных = Новый Массив;
    
    Если РежимАнализа = "ДИСКР" Тогда
        // Для дискретного режима собираем КОЛИЧЕСТВО БРАКА
        Для Каждого Строка Из Объект.Партии Цикл
            МассивДанных.Добавить(Строка.КоличествоБрака);
        КонецЦикла;
    Иначе // "Непрерывный"
        // Для непрерывного режима собираем ВЕРОЯТНОСТИ (ВерФакт)
        Для Каждого Строка Из Объект.Партии Цикл
            Если Строка.ОбъёмПартии > 0 Тогда
                МассивДанных.Добавить(Строка.ВерФакт);
            КонецЕсли;
        КонецЦикла;
    КонецЕсли;
    
    Возврат МассивДанных;
КонецФункции

