#Область ПостроениеГрафикаПлотности

&НаКлиенте
Процедура ПостроитьГрафикПлотности(Команда)
    Если Объект.Партии.Количество() = 0 Тогда
        Сообщить("Нет данных для построения графика.");
        Возврат;
    КонецЕсли;
    
    Объект.СтатусРаботы = "Построение графика плотности...";
    ПостроитьГрафикПлотностиНаСервере(Объект.РежимАнализа, Объект.ВыбранныйЗакон);
    Объект.СтатусРаботы = "Готово";
КонецПроцедуры

&НаСервере
Процедура ПостроитьГрафикПлотностиНаСервере(РежимАнализа, ВыбранныйЗакон)
    
    // Убеждаемся, что диаграмма существует
    Если Объект.ДиаграммаПлотности = Неопределено Тогда
        Объект.ДиаграммаПлотности = Новый Диаграмма;
    КонецЕсли;
    
    // Очистка и настройка
    Объект.ДиаграммаПлотности.Очистить();
    Объект.ДиаграммаПлотности.Обновление = Ложь;
    Объект.ДиаграммаПлотности.ТипДиаграммы = ТипДиаграммы.График;
    Объект.ДиаграммаПлотности.ОтображатьЛегенду = Истина;
    
    // Собираем данные
    МассивДанных = СобратьДанныеДляАнализа(РежимАнализа);
    Если МассивДанных.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;
    
    // Вычисляем статистики
    Среднее = ВычислитьСреднее(МассивДанных);
    Дисперсия = ВычислитьДисперсию(МассивДанных, Среднее);
    СКО = ВычислитьСКО(Дисперсия);
    МинЗнач = МассивДанных[0];
    МаксЗнач = МассивДанных[0];
    Для Каждого Значен Из МассивДанных Цикл
        Если Значен < МинЗнач Тогда МинЗнач = Значен; КонецЕсли;
        Если Значен > МаксЗнач Тогда МаксЗнач = Значен; КонецЕсли;
    КонецЦикла;
    
    // Определяем диапазон для графика (расширяем на 20%)
    Диапазон = МаксЗнач - МинЗнач;
    Если Диапазон = 0 Тогда Диапазон = 1; КонецЕсли;
    ОтображаемыйМин = МинЗнач - Диапазон * 0.2;
    ОтображаемыйМакс = МаксЗнач + Диапазон * 0.2;
    
    КоличествоТочек = 200;
    Шаг = (ОтображаемыйМакс - ОтображаемыйМин) / КоличествоТочек;
    
    // Выбираем закон распределения и строим график
    ИмяЗакона = "";
    Серия = Неопределено;
    
    Если ВыбранныйЗакон = "НОРМ" Тогда
        ИмяЗакона = "Нормальное (μ=" + Окр(Среднее,2) + ", σ=" + Окр(СКО,2) + ")";
        Серия = Объект.ДиаграммаПлотности.УстановитьСерию(ИмяЗакона);
        
        Для i = 0 По КоличествоТочек Цикл
            x = ОтображаемыйМин + i * Шаг;
            Плотность = (1 / (СКО * Sqrt(2 * 3.14159265358979))) * Exp(-Pow(x - Среднее, 2) / (2 * СКО * СКО));
            Точка = Объект.ДиаграммаПлотности.УстановитьТочку(x);
            Объект.ДиаграммаПлотности.УстановитьЗначение(Точка, Серия, Плотность);
        КонецЦикла;
        
    ИначеЕсли ВыбранныйЗакон = "РАВН" Тогда
        // Равномерное распределение
        ИмяЗакона = "Равномерное (min=" + Окр(МинЗнач,2) + ", max=" + Окр(МаксЗнач,2) + ")";
        Серия = Объект.ДиаграммаПлотности.УстановитьСерию(ИмяЗакона);
        
        Для i = 0 По КоличествоТочек Цикл
            x = ОтображаемыйМин + i * Шаг;
            Если x >= МинЗнач И x <= МаксЗнач Тогда
                Плотность = 1 / (МаксЗнач - МинЗнач);
            Иначе
                Плотность = 0;
            КонецЕсли;
            Точка = Объект.ДиаграммаПлотности.УстановитьТочку(x);
            Объект.ДиаграммаПлотности.УстановитьЗначение(Точка, Серия, Плотность);
        КонецЦикла;
        
    ИначеЕсли ВыбранныйЗакон = "ЭКСП" Тогда
        // Экспоненциальное распределение
        Лямбда = 1 / Среднее;
        ИмяЗакона = "Экспоненциальное (λ=" + Окр(Лямбда,4) + ")";
        Серия = Объект.ДиаграммаПлотности.УстановитьСерию(ИмяЗакона);
        
        Для i = 0 По КоличествоТочек Цикл
            x = ОтображаемыйМин + i * Шаг;
            Если x >= 0 Тогда
                Плотность = Лямбда * Exp(-Лямбда * x);
            Иначе
                Плотность = 0;
            КонецЕсли;
            Точка = Объект.ДиаграммаПлотности.УстановитьТочку(x);
            Объект.ДиаграммаПлотности.УстановитьЗначение(Точка, Серия, Плотность);
        КонецЦикла;
    КонецЕсли;
    
    Объект.ДиаграммаПлотности.Обновление = Истина; 
    
    Сообщить("Построен график для закона: " + ВыбранныйЗакон);
    Сообщить("Параметры: " + ИмяЗакона);
КонецПроцедуры
#КонецОбласти

#Область ПечатнаяФорма
&НаСервере
Процедура ПечатьРезультатов(Команда)
    Если Объект.Партии.Количество() = 0 Тогда
        Сообщить("Нет данных для печати.");
        Возврат;
	КонецЕсли;
    // Получаем макет
    Макет = ЭтотОбъект.ПолучитьМакет("МакетПечатнойФормы");
    ТабличныйДокумент = Новый ТабличныйДокумент;
    ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
    Если Макет = Неопределено Тогда
        Сообщить("Макет не найден!");
        Возврат;
    КонецЕсли;
    // Заполняем макет
    ЗаполнитьПечатнуюФорму(ТабличныйДокумент, Макет);
    
    // Показываем
    ТабличныйДокумент.Показать("Результаты проверки гипотезы"); 
	ТабличныйДокумент.Вывести(Макет);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПечатнуюФорму(ТабличныйДокумент, Макет)
    
    // Копируем области из макета
    ОбластьЗаголовок = Макет.ПолучитьОбласть("ОбластьЗаголовок");
    ОбластьПараметры = Макет.ПолучитьОбласть("ОбластьПараметры");
    ОбластьСтатистикаЗаголовок = Макет.ПолучитьОбласть("ОбластьСтатистикаЗаголовок");
    ОбластьСтатистикаСтрока = Макет.ПолучитьОбласть("ОбластьСтатистикаСтрока");
    ОбластьХиКвадратЗаголовок = Макет.ПолучитьОбласть("ОбластьХиКвадратЗаголовок");
    ОбластьХиКвадратСтрока = Макет.ПолучитьОбласть("ОбластьХиКвадратСтрока");
    ОбластьЧастотыЗаголовок = Макет.ПолучитьОбласть("ОбластьЧастотыЗаголовок");
    ОбластьЧастотыШапка = Макет.ПолучитьОбласть("ОбластьЧастотыШапка");
    ОбластьЧастотыСтрока = Макет.ПолучитьОбласть("ОбластьЧастотыСтрока");
    ОбластьЧастотыИтог = Макет.ПолучитьОбласть("ОбластьЧастотыИтог");
    ОбластьГистограммаЗаголовок = Макет.ПолучитьОбласть("ОбластьГистограммаЗаголовок");
    ОбластьГистограммаСтрока = Макет.ПолучитьОбласть("ОбластьГистограммаСтрока");
    ОбластьИтог = Макет.ПолучитьОбласть("ОбластьИтог");
    ОбластьПодвал = Макет.ПолучитьОбласть("ОбластьПодвал");
    
    // ====================================================
    // 1. ЗАГОЛОВОК
    // ====================================================
    ТабличныйДокумент.Вывести(ОбластьЗаголовок);
    
    // ====================================================
    // 2. ПАРАМЕТРЫ
    // ====================================================
    ТекстПараметры = "Дата: " + Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy HH:MM:SS");
    ТекстПараметры = ТекстПараметры + " | Режим: ";
    Если Объект.РежимАнализа = "НЕПРЕР" Тогда
        ТекстПараметры = ТекстПараметры + "непрерывный";
    Иначе
        ТекстПараметры = ТекстПараметры + "дискретный";
    КонецЕсли;
    
    ТекстПараметры = ТекстПараметры + " | Закон: ";
    Если Объект.РежимАнализа = "НЕПРЕР" Тогда
        Если Объект.ВыбранныйЗакон = "НОРМ" Тогда ТекстПараметры = ТекстПараметры + "Нормальное";
        ИначеЕсли Объект.ВыбранныйЗакон = "БЕТА" Тогда ТекстПараметры = ТекстПараметры + "Бета";
        Иначе ТекстПараметры = ТекстПараметры + "Равномерное";
        КонецЕсли;
    Иначе
        Если Объект.ВыбранныйЗакон = "БИНОМ" Тогда ТекстПараметры = ТекстПараметры + "Биномиальное";
        Иначе ТекстПараметры = ТекстПараметры + "Пуассона";
        КонецЕсли;
    КонецЕсли;
    
    ТекстПараметры = ТекстПараметры + " | Уровень значимости: " + Объект.УрвЗначи;
    
    // ВАЖНО: текст нужно помещать в параметр, а не в свойство Текст
    ОбластьПараметры.Параметры.ТекстПараметров = ТекстПараметры;
    ТабличныйДокумент.Вывести(ОбластьПараметры);
    
    // ====================================================
    // 3. СТАТИСТИЧЕСКИЕ ПОКАЗАТЕЛИ
    // ====================================================
    ТабличныйДокумент.Вывести(ОбластьСтатистикаЗаголовок);
    
    // n
    ОбластьСтатистикаСтрока.Параметры.Показатель = "Объем выборки (n)";
    ОбластьСтатистикаСтрока.Параметры.Значение = Формат(Объект.Партии.Количество(), "ЧГ=0");
    ТабличныйДокумент.Вывести(ОбластьСтатистикаСтрока);
    
    // Среднее
    ОбластьСтатистикаСтрока.Параметры.Показатель = "Среднее значение (x̄)";
    ОбластьСтатистикаСтрока.Параметры.Значение = Формат(Объект.Среднее, "ЧРЦ=6");
    ТабличныйДокумент.Вывести(ОбластьСтатистикаСтрока);
    
    // Дисперсия
    ОбластьСтатистикаСтрока.Параметры.Показатель = "Дисперсия (s²)";
    ОбластьСтатистикаСтрока.Параметры.Значение = Формат(Объект.Дисперсия, "ЧРЦ=6");
    ТабличныйДокумент.Вывести(ОбластьСтатистикаСтрока);
    
    // СКО
    ОбластьСтатистикаСтрока.Параметры.Показатель = "СКО (s)";
    ОбластьСтатистикаСтрока.Параметры.Значение = Формат(Объект.СКО, "ЧРЦ=6");
    ТабличныйДокумент.Вывести(ОбластьСтатистикаСтрока);
    
    // ====================================================
    // 4. ХИ-КВАДРАТ
    // ====================================================
    ТабличныйДокумент.Вывести(ОбластьХиКвадратЗаголовок);
    
    ОбластьХиКвадратСтрока.Параметры.ХиКвадрат = Формат(Объект.ХиКвадрат, "ЧРЦ=4");
    ОбластьХиКвадратСтрока.Параметры.СтепениСвободы = Формат(Объект.СтепеньСвободы, "ЧГ=0");
    ОбластьХиКвадратСтрока.Параметры.КритЗначение = Формат(Объект.КритЗначение, "ЧРЦ=4");
    ОбластьХиКвадратСтрока.Параметры.PValue = Формат(Объект.PValue, "ЧРЦ=6");
    ТабличныйДокумент.Вывести(ОбластьХиКвадратСтрока);
    
    // ====================================================
    // 5. ЧАСТОТЫ
    // ====================================================
    Если Объект.Частоты.Количество() > 0 Тогда
        ТабличныйДокумент.Вывести(ОбластьЧастотыЗаголовок);
        ТабличныйДокумент.Вывести(ОбластьЧастотыШапка);
        
        СуммаЭмп = 0;
        СуммаТеор = 0;
        СуммаВкладов = 0;
        
        Для Каждого СтрокаЧастоты Из Объект.Частоты Цикл
            ОбластьЧастотыСтрока.Параметры.Номер = СтрокаЧастоты.НомерИнтервала;
            ОбластьЧастотыСтрока.Параметры.Эмпирическая = Формат(СтрокаЧастоты.ЭмпирическаяЧастота, "ЧГ=0");
            ОбластьЧастотыСтрока.Параметры.Теоретическая = Формат(СтрокаЧастоты.ТеоретическаяЧастота, "ЧРЦ=2");
            Разность = СтрокаЧастоты.ЭмпирическаяЧастота - СтрокаЧастоты.ТеоретическаяЧастота;
            ОбластьЧастотыСтрока.Параметры.Разность = Формат(Разность, "ЧРЦ=2");
            ОбластьЧастотыСтрока.Параметры.Вклад = Формат(СтрокаЧастоты.ВкладВХиКвадрат, "ЧРЦ=4");
            ТабличныйДокумент.Вывести(ОбластьЧастотыСтрока);
            
            СуммаЭмп = СуммаЭмп + СтрокаЧастоты.ЭмпирическаяЧастота;
            СуммаТеор = СуммаТеор + СтрокаЧастоты.ТеоретическаяЧастота;
            СуммаВкладов = СуммаВкладов + СтрокаЧастоты.ВкладВХиКвадрат;
        КонецЦикла;
        
        // Итоговая строка
        ОбластьЧастотыИтог.Параметры.Эмпирическая = Формат(СуммаЭмп, "ЧГ=0");
        ОбластьЧастотыИтог.Параметры.Теоретическая = Формат(СуммаТеор, "ЧРЦ=2");
        ОбластьЧастотыИтог.Параметры.Вклад = Формат(СуммаВкладов, "ЧРЦ=4");
        ТабличныйДокумент.Вывести(ОбластьЧастотыИтог);
    КонецЕсли;
    
    // ====================================================
    // 6. ГИСТОГРАММА
    // ====================================================
    Если Объект.Диаграмма.Количество() > 0 Тогда
        ТабличныйДокумент.Вывести(ОбластьГистограммаЗаголовок);
        
        // Находим максимальную частоту
        МаксЧастота = 0;
        Для Каждого СтрокаДиагр Из Объект.Диаграмма Цикл
            Если СтрокаДиагр.Частота > МаксЧастота Тогда
                МаксЧастота = СтрокаДиагр.Частота;
            КонецЕсли;
        КонецЦикла;
        
        Масштаб = 40 / МаксЧастота;
        Если Масштаб <= 0 Тогда Масштаб = 1; КонецЕсли;
        
        Для Каждого СтрокаДиагр Из Объект.Диаграмма Цикл
            КоличествоСимволов = Цел(СтрокаДиагр.Частота * Масштаб);
            Если КоличествоСимволов < 1 И СтрокаДиагр.Частота > 0 Тогда
                КоличествоСимволов = 1;
            КонецЕсли;
            
            Полоса = "";
            Для j = 1 По КоличествоСимволов Цикл
                Полоса = Полоса + "█";
            КонецЦикла;
            
            ОбластьГистограммаСтрока.Параметры.Интервал = СтрокаДиагр.Интервал;
            ОбластьГистограммаСтрока.Параметры.Частота = Формат(СтрокаДиагр.Частота, "ЧГ=0");
            ОбластьГистограммаСтрока.Параметры.Полоса = Полоса;
            ТабличныйДокумент.Вывести(ОбластьГистограммаСтрока);
        КонецЦикла;
    КонецЕсли;
    
    // ====================================================
    // 7. ИТОГ
    // ====================================================
    ОбластьИтог.Параметры.Результат = Объект.РезультатПроверки;
    ТабличныйДокумент.Вывести(ОбластьИтог);
    
    // ====================================================
    // 8. ПОДВАЛ
    // ====================================================
    ОбластьПодвал.Параметры.Дата = Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy");
    ОбластьПодвал.Параметры.Подпись = "Разработчик: Статистическая система";
    ТабличныйДокумент.Вывести(ОбластьПодвал);
    
КонецПроцедуры
#КонецОбласти 

#Область ПостроениеКомбинированнойДиаграммы

&НаКлиенте
Процедура ПостроитьКомбинированнуюДиаграмму(Команда)
    Если Объект.Партии.Количество() = 0 Тогда
        Сообщить("Нет данных для построения диаграммы.");
        Возврат;
    КонецЕсли;
    
    Объект.СтатусРаботы = "Построение комбинированной диаграммы...";
    ПостроитьКомбинированнуюДиаграммуНаСервере(Объект.РежимАнализа, Объект.ВыбранныйЗакон);
    Объект.СтатусРаботы = "Готово";
КонецПроцедуры

&НаСервере
Процедура ПостроитьКомбинированнуюДиаграммуНаСервере(РежимАнализа, ВыбранныйЗакон)
    
    // Убеждаемся, что диаграмма существует
    Если Объект.Диаграмма = Неопределено Тогда
        Объект.Диаграмма = Новый Диаграмма;
    КонецЕсли;
    
    // Очистка и настройка
    Объект.Диаграмма.Очистить();
    Объект.Диаграмма.Обновление = Ложь;
    
    // Получаем данные
    МассивДанных = СобратьДанныеДляАнализа(РежимАнализа);
    Если МассивДанных.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;
    
    // Вычисляем статистики
    Среднее = ВычислитьСреднее(МассивДанных);
    Дисперсия = ВычислитьДисперсию(МассивДанных, Среднее);
    СКО = ВычислитьСКО(Дисперсия);
    
    // Находим минимум и максимум
    МинЗнач = МассивДанных[0];
    МаксЗнач = МассивДанных[0];
    Для Каждого Значен Из МассивДанных Цикл
        Если Значен < МинЗнач Тогда МинЗнач = Значен; КонецЕсли;
        Если Значен > МаксЗнач Тогда МаксЗнач = Значен; КонецЕсли;
    КонецЦикла;
    
    // Определяем количество интервалов для гистограммы
    КоличествоДанных = МассивДанных.Количество();
    КоличествоИнтервалов = Цел(1 + 3.322 * Log10(КоличествоДанных));
    Если КоличествоИнтервалов < 5 Тогда КоличествоИнтервалов = 5; КонецЕсли;
    Если КоличествоИнтервалов > 15 Тогда КоличествоИнтервалов = 15; КонецЕсли;
    
    // Добавляем зазор
    Дельта = (МаксЗнач - МинЗнач) * 0.05;
    Если Дельта = 0 Тогда Дельта = 1; КонецЕсли;
    МинГраница = МинЗнач - Дельта;
    МаксГраница = МаксЗнач + Дельта;
    
    ШагИнтервала = (МаксГраница - МинГраница) / КоличествоИнтервалов;
    
    // ========== 1. Строим ГИСТОГРАММУ ==========
    СерияГистограмма = Объект.Диаграмма.Серии.Добавить("Эмпирическая гистограмма");
    
    // Подсчитываем частоты
    Для i = 0 По КоличествоИнтервалов - 1 Цикл
        НижняяГраница = МинГраница + i * ШагИнтервала;
        ВерхняяГраница = МинГраница + (i + 1) * ШагИнтервала;
        
        // Считаем частоту
        Частота = 0;
        Для Каждого Значен Из МассивДанных Цикл
            Если Значен >= НижняяГраница И Значен < ВерхняяГраница Тогда
                Частота = Частота + 1;
            КонецЕсли;
        КонецЦикла;
        
        // Преобразуем частоту в плотность вероятности
        ПлотностьВероятности = Частота / (КоличествоДанных * ШагИнтервала);
        
        // Используем середину интервала для точки
        СерединаИнтервала = (НижняяГраница + ВерхняяГраница) / 2;
        
        Точка = Объект.Диаграмма.УстановитьТочку(СерединаИнтервала);
        Объект.Диаграмма.УстановитьЗначение(Точка, СерияГистограмма, ПлотностьВероятности);
    КонецЦикла;
    
    // ========== 2. Строим ТЕОРЕТИЧЕСКУЮ КРИВУЮ ПЛОТНОСТИ (линия) ==========
    // Определяем диапазон для отображения
    Диапазон = МаксЗнач - МинЗнач;
    Если Диапазон = 0 Тогда Диапазон = 1; КонецЕсли;
    ОтображаемыйМин = МинЗнач - Диапазон * 0.2;
    ОтображаемыйМакс = МаксЗнач + Диапазон * 0.2;
    
    КоличествоТочек = 200;
    Шаг = (ОтображаемыйМакс - ОтображаемыйМин) / КоличествоТочек;
    
    // Добавляем серию для теоретической кривой (тип - ГРАФИК/ЛИНИЯ)
    ИмяЗакона = "";
    СерияТеория = Неопределено;
    
    Если ВыбранныйЗакон = "НОРМ" Тогда
        ИмяЗакона = "Нормальное распределение (μ=" + Окр(Среднее,2) + ", σ=" + Окр(СКО,2) + ")";
        СерияТеория = Объект.Диаграмма.Серии.Добавить(ИмяЗакона);
        СерияТеория.ТипДиаграммы = ТипДиаграммы.График;  // ЛИНИЯ!
        
        Для i = 0 По КоличествоТочек Цикл
            x = ОтображаемыйМин + i * Шаг;
            // Формула нормального распределения
            Плотность = (1 / (СКО * Sqrt(2 * 3.14159265358979))) * Exp(-Pow(x - Среднее, 2) / (2 * СКО * СКО));
            
            Точка = Объект.Диаграмма.УстановитьТочку(x);
            Объект.Диаграмма.УстановитьЗначение(Точка, СерияТеория, Плотность);
        КонецЦикла;
        
    ИначеЕсли ВыбранныйЗакон = "РАВН" Тогда
        ИмяЗакона = "Равномерное распределение (min=" + Окр(МинЗнач,2) + ", max=" + Окр(МаксЗнач,2) + ")";
        СерияТеория = Объект.Диаграмма.Серии.Добавить(ИмяЗакона);
        СерияТеория.ТипДиаграммы = ТипДиаграммы.График;  // ЛИНИЯ!
        
        Для i = 0 По КоличествоТочек Цикл
            x = ОтображаемыйМин + i * Шаг;
            Если x >= МинЗнач И x <= МаксЗнач Тогда
                Плотность = 1 / (МаксЗнач - МинЗнач);
            Иначе
                Плотность = 0;
            КонецЕсли;
            
            Точка = Объект.Диаграмма.УстановитьТочку(x);
            Объект.Диаграмма.УстановитьЗначение(Точка, СерияТеория, Плотность);
        КонецЦикла;
        
    ИначеЕсли ВыбранныйЗакон = "ЭКСП" Тогда
        Лямбда = 1 / Среднее;
        ИмяЗакона = "Экспоненциальное распределение (λ=" + Окр(Лямбда,4) + ")";
        СерияТеория = Объект.Диаграмма.Серии.Добавить(ИмяЗакона);
        СерияТеория.ТипДиаграммы = ТипДиаграммы.График;  // ЛИНИЯ!
        
        Для i = 0 По КоличествоТочек Цикл
            x = ОтображаемыйМин + i * Шаг;
            Если x >= 0 Тогда
                Плотность = Лямбда * Exp(-Лямбда * x);
            Иначе
                Плотность = 0;
            КонецЕсли;
            
            Точка = Объект.Диаграмма.УстановитьТочку(x);
            Объект.Диаграмма.УстановитьЗначение(Точка, СерияТеория, Плотность);
        КонецЦикла;
    КонецЕсли;
    
    // Настройка внешнего вида
    Объект.Диаграмма.ТипДиаграммы = ТипДиаграммы.График;  // Основной тип - график, чтобы линия была видна
    Объект.Диаграмма.ОтображатьЛегенду = Истина;
    Объект.Диаграмма.Обновление = Истина;
    
    Сообщить("Построена комбинированная диаграмма");
    Сообщить("Гистограмма (столбцы) + теоретическая кривая (линия)");
КонецПроцедуры
#КонецОбласти